{
  "id": "glitch-agent-deploy",
  "version": "1.0.0",
  "description": "Manage deployments of the Glitch agent: check current ARN, update SSM parameters after a fresh deploy, and check CodeBuild status. Use when the user asks to deploy, redeploy, wire up ARNs, check deploy status, or after running agentcore deploy locally.",
  "triggers": [
    "deploy",
    "redeploy",
    "deploy agent",
    "deploy glitch",
    "agentcore deploy",
    "update arn",
    "wire up arn",
    "fresh deploy",
    "new arn",
    "agent arn",
    "glitch arn",
    "codebuild",
    "build status",
    "deploy status",
    "cdk deploy",
    "deploy cdk",
    "deploy stack",
    "GlitchAgentCoreStack",
    "update ssm",
    "ssm parameter"
  ],
  "tags": ["deployment", "infrastructure", "agentcore", "ssm", "cdk", "codebuild"],
  "priority": 80,
  "model_allowlist": null,
  "model_denylist": null,
  "required_tools": [
    "get_deployed_arns",
    "update_glitch_arn_in_ssm",
    "check_codebuild_deploy_status"
  ],
  "author": "Glitch Team"
}
