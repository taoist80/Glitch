    "deploy",
    "redeploy",
    "deploy agent",
    "deploy sentinel",
    "deploy glitch",
    "agentcore deploy",
    "update arn",
    "wire up arn",
    "fresh deploy",
    "new arn",
    "agent arn",
    "sentinel arn",
    "glitch arn",
    "codebuild",
    "build status",
    "deploy status",
    "cdk deploy",
    "deploy cdk",
    "deploy stack",
    "GlitchSentinelStack",
    "GlitchAgentCoreStack",
    "update ssm",
    "ssm parameter",
    "cross-agent",
    "agents not talking",
    "invoke sentinel failed",
    "invoke glitch failed"
  ],
  "tags": ["deployment", "infrastructure", "agentcore", "ssm", "cdk", "codebuild"],
  "priority": 80,
  "model_allowlist": null,
  "model_denylist": null,
  "required_tools": [
    "get_deployed_arns",
    "update_glitch_arn_in_ssm",
    "update_sentinel_arn_in_ssm",
    "update_both_arns_in_ssm",
    "deploy_cdk_stack",
    "check_codebuild_deploy_status"
  ],
  "author": "Glitch Team"
}
