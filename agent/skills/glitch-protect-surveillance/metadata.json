{
  "id": "glitch-protect-surveillance",
  "version": "1.0.0",
  "description": "UniFi Protect surveillance integration: entity detection, identification, anomaly detection, threat assessment, cross-camera tracking, and adaptive alerting. Use when user mentions Protect, cameras, surveillance, vehicles, license plates, alerts, security, motion, or UniFi.",
  "triggers": [
    "protect",
    "camera",
    "surveillance",
    "motion",
    "vehicle",
    "license plate",
    "plate",
    "person",
    "face",
    "entity",
    "alert",
    "monitoring",
    "security",
    "threat",
    "hostile",
    "anomaly",
    "track",
    "dossier",
    "baseline",
    "false positive",
    "who is at",
    "what car",
    "identify",
    "register entity",
    "daily briefing",
    "security report",
    "front door",
    "driveway",
    "backyard",
    "unifi"
  ],
  "tags": [
    "security",
    "surveillance",
    "unifi",
    "protect",
    "vision",
    "entity-tracking",
    "anomaly-detection",
    "alerting"
  ],
  "priority": 90,
  "model_allowlist": null,
  "model_denylist": null,
  "required_tools": [
    "protect_get_cameras",
    "protect_get_events",
    "protect_get_snapshot",
    "protect_classify_snapshot",
    "protect_db_store_observation",
    "protect_db_get_baseline",
    "protect_should_alert",
    "protect_send_telegram_alert",
    "protect_register_entity",
    "protect_search_entities",
    "vision_agent"
  ],
  "author": "Glitch Team"
}
